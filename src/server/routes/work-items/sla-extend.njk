{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{# RA-131: Extend SLA clock #}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Work item " + workItem.id
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errorSummary %}
        {{ govukErrorSummary({
          titleText: errorSummary.titleText,
          errorList: errorSummary.items,
          attributes: { "data-testid": "sla-extend-error-summary" }
        }) }}
      {% endif %}

      <form method="post"
            action="{{ formAction }}"
            novalidate
            data-testid="sla-extend-form">
        <input type="hidden" name="crumb" value="{{ crumb }}" />

        {{ govukCharacterCount({
          id: "field-reason",
          name: "reason",
          maxlength: reasonMaxLength,
          label: {
            text: "Reason for extending the SLA",
            classes: "govuk-label--s"
          },
          hint: {
            text: "Explain why the SLA deadline needs to be extended."
          },
          value: values.reason,
          errorMessage: { text: fieldErrors["reason"] } if fieldErrors["reason"] else null,
          attributes: { "data-testid": "sla-extend-reason" }
        }) }}

        {{ govukInput({
          id: "field-additionalDays",
          name: "additionalDays",
          label: {
            text: "Number of additional days",
            classes: "govuk-label--s"
          },
          hint: {
            text: "Enter a whole number between 1 and " + maxDays + "."
          },
          value: values.additionalDays,
          inputmode: "numeric",
          classes: "govuk-input--width-5",
          errorMessage: { text: fieldErrors["additionalDays"] } if fieldErrors["additionalDays"] else null,
          attributes: { "data-testid": "sla-extend-days" }
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Extend SLA",
            attributes: { "data-testid": "sla-extend-submit" }
          }) }}
          <a class="govuk-link"
             data-testid="sla-extend-cancel"
             href="{{ cancelHref }}">Cancel</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
