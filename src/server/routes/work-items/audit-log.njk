{% extends 'layouts/page.njk' %}

{# ---------------------------------------------------------------- #}
{# Standalone audit log page for a work item (RA-97).                #}
{#                                                                   #}
{# Framework-provided audit timeline: every state-changing engine    #}
{# call (task complete, action applied, assignment change, note      #}
{# added) appends one entry on the backend. Projected chronologically #}
{# (oldest-first) so we render top-to-bottom without re-sorting.     #}
{# ---------------------------------------------------------------- #}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Work item " + workItem.id
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if workItem.auditLog and workItem.auditLog.length > 0 %}
        <ol class="govuk-list" data-testid="work-item-audit-log">
          {% for entry in workItem.auditLog %}
            <li class="govuk-!-margin-bottom-3" data-testid="work-item-audit-entry-{{ entry.id }}">
              <p class="govuk-body govuk-!-margin-bottom-1">
                <strong>{{ entry.actionDisplayName }}</strong>
                {% if entry.summary %}
                  — {{ entry.summary }}
                {% endif %}
              </p>
              <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-1">
                {{ entry.createdByName or entry.createdBy or "System" }} — {{ entry.createdAt }}
              </p>
              {% if entry.detailRows and entry.detailRows.length > 0 %}
                <details class="govuk-details govuk-!-margin-top-1 govuk-!-margin-bottom-0" data-testid="work-item-audit-entry-details">
                  <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">Show details</span>
                  </summary>
                  <div class="govuk-details__text">
                    <dl class="govuk-summary-list govuk-summary-list--no-border govuk-!-margin-bottom-0">
                      {% for row in entry.detailRows %}
                        <div class="govuk-summary-list__row">
                          <dt class="govuk-summary-list__key">{{ row.key }}</dt>
                          <dd class="govuk-summary-list__value">
                            {% if row.preformatted %}
                              <pre class="govuk-!-font-size-14 govuk-!-margin-top-0 govuk-!-margin-bottom-0"
                                   data-testid="work-item-audit-entry-detail-pre"><code>{{ row.value }}</code></pre>
                            {% elif row.multiline %}
                              {% for line in row.value.split('\n') %}
                                <p class="govuk-body govuk-!-margin-bottom-1">{{ line }}</p>
                              {% endfor %}
                            {% else %}
                              {{ row.value }}
                            {% endif %}
                          </dd>
                        </div>
                      {% endfor %}
                    </dl>
                  </div>
                </details>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-audit-log">
          No actions have been recorded against this work item yet.
        </p>
      {% endif %}

      <p class="govuk-body">
        <a class="govuk-link" href="/work-items/{{ workItem.id }}">Back to work item</a>
      </p>
    </div>
  </div>
{% endblock %}
