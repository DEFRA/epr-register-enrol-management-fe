{% extends 'layouts/page.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/task-list/macro.njk" import govukTaskList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{# ---------------------------------------------------------------- #}
{# Generic work item detail template.                                #}
{#                                                                   #}
{# Used as the fallback when the work item's `(typeId,                #}
{# templateVersion)` pair has no module-specific template registered. #}
{# Renders the envelope (id, type, state, submitter, payload), the   #}
{# tasks projected by the engine, and the available actions, all in  #}
{# GOV.UK Design System macros only — no JavaScript dependency.       #}
{# ---------------------------------------------------------------- #}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Work item " + workItem.applicationRef
  }) }}

  {# RA-132. Generic flash-banner rendered above the existing per-feature  #}
  {# banners. Set by handlers via `request.yar.flash('flashBanner', ...)`  #}
  {# with shape `{type: 'success' | 'error', title?, text}`.                #}
  {% if flashBanner %}
    {{ govukNotificationBanner({
      type: flashBanner.type,
      titleText: flashBanner.title or (flashBanner.type == 'success' and 'Success' or 'There is a problem'),
      text: flashBanner.text,
      attributes: { "data-testid": "work-item-flash-banner" }
    }) }}
  {% endif %}

  {% if successBanner %}
    {{ govukNotificationBanner({
      type: 'success',
      titleText: 'Work item created — ' + successBanner.reference,
      text: 'Reference: ' + successBanner.reference,
      attributes: { "data-testid": "work-item-success-banner" }
    }) }}
  {% endif %}

  {% if notice %}
    {% if notice.kind == 'error' %}
      {{ govukErrorSummary({
        titleText: notice.title or "There is a problem",
        errorList: [{ text: notice.message }]
      }) }}
    {% else %}
      {{ govukNotificationBanner({
        type: 'success',
        titleText: notice.title or 'Success',
        text: notice.message
      }) }}
    {% endif %}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ govukSummaryList({
        attributes: { "data-testid": "work-item-summary" },
        rows: [
          { key: { text: "Application ref" }, value: { text: workItem.applicationRef } },
          { key: { text: "Type" },         value: { text: workItem.typeDisplayName } },
          { key: { text: "State" },        value: { text: workItem.stateDisplayName } },
          { key: { text: "Submitted at" }, value: { text: workItem.submittedAt } },
          { key: { text: "Submitted by" }, value: { text: workItem.submittedBy or "—" } },
          { key: { text: "Last modified" }, value: { text: workItem.lastModifiedAt } },
          { key: { text: "Assigned to" }, value: { text: assignment.assignedToName or "Unassigned" } }
        ]
      }) }}

      {# Block for type-specific summary content rendered immediately below #}
      {# the generic envelope summary — used by RA-132 for the accredited   #}
      {# determination metadata once a re-accreditation reaches `approved`. #}
      {% block summaryListExtra %}{% endblock %}

      {# Block for type-specific primary actions rendered above the         #}
      {# assignment / tasks / actions panels — used by RA-132 to host the   #}
      {# "Approve" CTA on the re-accreditation detail page.                 #}
      {% block primaryActions %}{% endblock %}

      {# --------------------------- Assignment --------------------------- #}
      {# RA-95. Assign-role users see a picker and re-assign / unassign    #}
      {# buttons. Standard users see a "Take this work item" button only   #}
      {# when the item is currently unassigned. Backend enforces the same  #}
      {# rules — the BFF is just providing a sensible UI.                  #}
      <h2 class="govuk-heading-m">Assignment</h2>
      <div data-testid="work-item-assignment">
        {% if assignment.canAssignAnyone %}
          <form method="post"
                action="/work-items/{{ workItem.id }}/assign"
                class="govuk-!-margin-bottom-3"
                novalidate>
            <input type="hidden" name="crumb" value="{{ crumb }}" />
            {{ govukSelect({
              id: "assign-assignee-id",
              name: "assigneeId",
              label: { text: "Assign to", classes: "govuk-label--s" },
              items: assignment.assignableUsers,
              attributes: { "data-testid": "assign-select" }
            }) }}
            <div class="govuk-button-group">
              {{ govukButton({
                text: assignment.isUnassigned and "Assign" or "Re-assign",
                attributes: { "data-testid": "assign-submit" }
              }) }}
              {% if assignment.canUnassign %}
                {# Distinct form so the unassign button doesn't carry the   #}
                {# select payload.                                           #}
              {% endif %}
            </div>
          </form>
          {% if assignment.canUnassign %}
            <form method="post"
                  action="/work-items/{{ workItem.id }}/unassign"
                  novalidate>
              <input type="hidden" name="crumb" value="{{ crumb }}" />
              {{ govukButton({
                text: "Unassign",
                classes: "govuk-button--secondary",
                attributes: { "data-testid": "unassign-submit" }
              }) }}
            </form>
          {% endif %}
        {% elif assignment.canSelfAssign %}
          <form method="post"
                action="/work-items/{{ workItem.id }}/self-assign"
                novalidate>
            <input type="hidden" name="crumb" value="{{ crumb }}" />
            {{ govukButton({
              text: "Take this work item",
              attributes: { "data-testid": "self-assign-submit" }
            }) }}
          </form>
        {% elif assignment.callerIsAssignee %}
          <p class="govuk-body" data-testid="assignment-caller-is-assignee">
            This work item is assigned to you.
          </p>
        {% else %}
          <p class="govuk-body" data-testid="assignment-readonly">
            {% if assignment.isUnassigned %}
              This work item is not currently assigned.
            {% else %}
              This work item is assigned to {{ assignment.assignedToName }}.
            {% endif %}
          </p>
        {% endif %}
      </div>

      {# ------------------------------ Tasks ------------------------------ #}
      {# RA-129. Task progression + per-task notes live on a dedicated      #}
      {# /tasks page so the summary stays focused on envelope, assignment,  #}
      {# available actions and the audit log. The summary keeps a read-only #}
      {# progress indicator + a deep link.                                  #}
      <h2 class="govuk-heading-m">Tasks</h2>

      {% if workItem.taskProgress.total > 0 %}
        <p class="govuk-body" data-testid="work-item-task-progress">
          {{ workItem.taskProgress.completed }} of {{ workItem.taskProgress.total }} tasks complete.
        </p>
        <p class="govuk-body">
          <a class="govuk-link"
             data-testid="work-item-tasks-link"
             href="/work-items/{{ workItem.id }}/tasks">Tasks &amp; notes ({{ workItem.taskProgress.total }})</a>
        </p>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-tasks">
          No tasks are required for this work item in its current state.
        </p>
        <p class="govuk-body">
          <a class="govuk-link"
             data-testid="work-item-tasks-link"
             href="/work-items/{{ workItem.id }}/tasks">Tasks &amp; notes</a>
        </p>
      {% endif %}

      {# ---------------------------- Actions ----------------------------- #}
      {# Wrapped in an override-able block so type-specific templates can   #}
      {# replace the generic action list — used by RA-132 to suppress      #}
      {# decision actions once a re-accreditation reaches a terminal state.#}
      {% block actionsPanel %}
      <h2 class="govuk-heading-m">Actions</h2>

      {% if workItem.availableActions and workItem.availableActions.length > 0 %}
        <div class="govuk-button-group" data-testid="work-item-actions">
          {% block approveAction %}{% endblock %}
          {% for action in workItem.availableActions %}
            {% if action.actionId == 'sla-extend' %}
              {% if canManageSla %}
                <div class="govuk-!-display-inline-block">
                  <a class="govuk-button"
                     data-module="govuk-button"
                     role="button"
                     draggable="false"
                     data-testid="action-sla-extend"
                     href="/work-items/{{ workItem.id }}/sla/extend">{{ action.displayName }}</a>
                </div>
                {# RA-131. Override SLA is BFF-only (no backend workflow        #}
                {# transition) so it isn't projected into availableActions.     #}
                {# Render it immediately after Extend SLA, matching its style.  #}
                <div class="govuk-!-display-inline-block">
                  <a class="govuk-button"
                     data-module="govuk-button"
                     role="button"
                     draggable="false"
                     data-testid="action-sla-override"
                     href="/work-items/{{ workItem.id }}/sla/override">Override SLA</a>
                </div>
              {% endif %}
            {% elif action.actionId == 'withdraw' or action.actionId.startsWith('withdraw-') %}
              {# RA-188. Withdraw goes through a confirmation interstitial    #}
              {# so the user can add an optional note and back out.           #}
              <div class="govuk-!-display-inline-block">
                <a class="govuk-button govuk-button--warning"
                   data-module="govuk-button"
                   role="button"
                   draggable="false"
                   data-testid="action-{{ action.actionId }}"
                   href="/work-items/{{ workItem.id }}/actions/{{ action.actionId }}/confirm">{{ action.displayName }}</a>
              </div>
            {% else %}
              <form method="post"
                    action="/work-items/{{ workItem.id }}/actions/{{ action.actionId }}"
                    class="govuk-!-display-inline-block"
                    novalidate>
                <input type="hidden" name="crumb" value="{{ crumb }}" />
                {{ govukButton({
                  text: action.displayName,
                  classes: action.actionId == 'reject' and 'govuk-button--warning' or '',
                  attributes: { "data-testid": "action-" + action.actionId }
                }) }}
              </form>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-actions">
          No actions are currently available for this work item.
        </p>
      {% endif %}
      {% endblock %}

      {# ----------------------------- SLA -------------------------------- #}
      {# RA-131. Extend SLA and Override SLA buttons live in the Actions   #}
      {# panel above. This section shows the SLA clock status (when the    #}
      {# backend exposes it) so team leaders can see what they're acting   #}
      {# on before clicking the buttons.                                   #}
      {% if canManageSla and workItem.slaClock %}
        <h2 class="govuk-heading-m">SLA status</h2>
        <p class="govuk-body" data-testid="sla-clock-info">
          Target: {{ workItem.slaClock.targetDuration }} &mdash;
          {% if workItem.slaClock.breached %}
            <strong class="govuk-tag govuk-tag--red">Breached</strong>
          {% else %}
            On track
          {% endif %}
        </p>
      {% endif %}

      {# --------------------------- Audit log ---------------------------- #}
      {# RA-97. The audit log lives on its own page (`/work-items/{id}/    #}
      {# audit-log`) so the detail view stays focused on current state,   #}
      {# tasks and actions. Link out so users can still reach it in a     #}
      {# single click.                                                    #}
      <h2 class="govuk-heading-m">Audit log</h2>
      <p class="govuk-body">
        <a class="govuk-link"
           data-testid="work-item-audit-log-link"
           href="/work-items/{{ workItem.id }}/audit-log">View audit log</a>
      </p>
    </div>
  </div>
{% endblock %}
