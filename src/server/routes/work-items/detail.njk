{% extends 'layouts/page.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/task-list/macro.njk" import govukTaskList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{# ---------------------------------------------------------------- #}
{# Generic work item detail template.                                #}
{#                                                                   #}
{# Used as the fallback when the work item's `(typeId,                #}
{# templateVersion)` pair has no module-specific template registered. #}
{# Renders the envelope (id, type, state, submitter, payload), the   #}
{# tasks projected by the engine, and the available actions, all in  #}
{# GOV.UK Design System macros only — no JavaScript dependency.       #}
{# ---------------------------------------------------------------- #}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Work item " + workItem.id
  }) }}

  {% if notice %}
    {{ govukNotificationBanner({
      type: notice.kind == 'error' and 'important' or 'success',
      titleText: notice.title or (notice.kind == 'error' and 'There was a problem' or 'Success'),
      text: notice.message
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ govukSummaryList({
        attributes: { "data-testid": "work-item-summary" },
        rows: [
          { key: { text: "Id" },           value: { text: workItem.id } },
          { key: { text: "Type" },         value: { text: workItem.typeDisplayName } },
          { key: { text: "State" },        value: { text: workItem.stateDisplayName } },
          { key: { text: "Template version" }, value: { text: workItem.templateVersion } },
          { key: { text: "Submitted at" }, value: { text: workItem.submittedAt } },
          { key: { text: "Submitted by" }, value: { text: workItem.submittedBy or "—" } },
          { key: { text: "Last modified" }, value: { text: workItem.lastModifiedAt } },
          { key: { text: "Assigned to" }, value: { text: assignment.assignedToName or "Unassigned" } }
        ]
      }) }}

      {# --------------------------- Assignment --------------------------- #}
      {# RA-95. Assign-role users see a picker and re-assign / unassign    #}
      {# buttons. Standard users see a "Take this work item" button only   #}
      {# when the item is currently unassigned. Backend enforces the same  #}
      {# rules — the BFF is just providing a sensible UI.                  #}
      <h2 class="govuk-heading-m">Assignment</h2>
      <div data-testid="work-item-assignment">
        {% if assignment.canAssignAnyone %}
          <form method="post"
                action="/work-items/{{ workItem.id }}/assign"
                class="govuk-!-margin-bottom-3"
                novalidate>
            {{ govukSelect({
              id: "assign-assignee-id",
              name: "assigneeId",
              label: { text: "Assign to", classes: "govuk-label--s" },
              items: assignment.assignableUsers,
              attributes: { "data-testid": "assign-select" }
            }) }}
            <div class="govuk-button-group">
              {{ govukButton({
                text: assignment.isUnassigned and "Assign" or "Re-assign",
                attributes: { "data-testid": "assign-submit" }
              }) }}
              {% if assignment.canUnassign %}
                {# Distinct form so the unassign button doesn't carry the   #}
                {# select payload.                                           #}
              {% endif %}
            </div>
          </form>
          {% if assignment.canUnassign %}
            <form method="post"
                  action="/work-items/{{ workItem.id }}/unassign"
                  novalidate>
              {{ govukButton({
                text: "Unassign",
                classes: "govuk-button--secondary",
                attributes: { "data-testid": "unassign-submit" }
              }) }}
            </form>
          {% endif %}
        {% elif assignment.canSelfAssign %}
          <form method="post"
                action="/work-items/{{ workItem.id }}/assign"
                novalidate>
            <input type="hidden" name="assigneeId" value="{{ assignment.selfAssignUserId }}" />
            {% if assignment.selfAssignUserName %}
              <input type="hidden" name="assigneeName" value="{{ assignment.selfAssignUserName }}" />
            {% endif %}
            {{ govukButton({
              text: "Take this work item",
              attributes: { "data-testid": "self-assign-submit" }
            }) }}
          </form>
        {% elif assignment.callerIsAssignee %}
          <p class="govuk-body" data-testid="assignment-caller-is-assignee">
            This work item is assigned to you.
          </p>
        {% else %}
          <p class="govuk-body" data-testid="assignment-readonly">
            {% if assignment.isUnassigned %}
              This work item is not currently assigned.
            {% else %}
              This work item is assigned to {{ assignment.assignedToName }}.
            {% endif %}
          </p>
        {% endif %}
      </div>

      {# ------------------------------ Tasks ------------------------------ #}
      <h2 class="govuk-heading-m">Tasks</h2>

      {% if workItem.tasks and workItem.tasks.length > 0 %}
        <ul class="govuk-list" data-testid="work-item-tasks">
          {% for task in workItem.tasks %}
            <li class="govuk-!-margin-bottom-3" data-testid="work-item-task-{{ task.taskId }}">
              <span class="govuk-!-margin-right-2">{{ task.displayName }}</span>
              {% if task.isComplete %}
                {{ govukTag({ text: "Complete", classes: "govuk-tag--green" }) }}
              {% else %}
                {{ govukTag({ text: "Incomplete", classes: "govuk-tag--blue" }) }}
                <form method="post"
                      action="/work-items/{{ workItem.id }}/tasks/{{ task.taskId }}/complete"
                      class="govuk-!-display-inline-block govuk-!-margin-left-2"
                      novalidate>
                  {{ govukButton({
                    text: "Mark complete",
                    classes: "govuk-button--secondary govuk-!-margin-bottom-0",
                    attributes: { "data-testid": "complete-task-" + task.taskId }
                  }) }}
                </form>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-tasks">
          No tasks are required for this work item in its current state.
        </p>
      {% endif %}

      {# ---------------------------- Actions ----------------------------- #}
      <h2 class="govuk-heading-m">Actions</h2>

      {% if workItem.availableActions and workItem.availableActions.length > 0 %}
        <div class="govuk-button-group" data-testid="work-item-actions">
          {% for action in workItem.availableActions %}
            <form method="post"
                  action="/work-items/{{ workItem.id }}/actions/{{ action.actionId }}"
                  class="govuk-!-display-inline-block"
                  novalidate>
              {{ govukButton({
                text: action.displayName,
                classes: action.actionId == 'reject' and 'govuk-button--warning' or '',
                attributes: { "data-testid": "action-" + action.actionId }
              }) }}
            </form>
          {% endfor %}
        </div>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-actions">
          No actions are currently available for this work item.
        </p>
      {% endif %}

      {# ------------------------------ Notes ----------------------------- #}
      {# RA-96. Notes are an append-only audit narrative attached to every #}
      {# work item by the framework. Any authenticated user can add one;   #}
      {# the backend snapshots author identity onto the note. Existing     #}
      {# notes are projected newest-first by the backend so we render      #}
      {# them in the order received.                                       #}
      <h2 class="govuk-heading-m" id="notes">Notes</h2>

      <form method="post"
            action="/work-items/{{ workItem.id }}/notes"
            class="govuk-!-margin-bottom-6"
            novalidate>
        {{ govukCharacterCount({
          id: "note-text",
          name: "text",
          maxlength: 4000,
          rows: 5,
          label: {
            text: "Add a note",
            classes: "govuk-label--s"
          },
          hint: {
            text: "Notes are visible to anyone who can see this work item and cannot be edited or deleted."
          },
          attributes: { "data-testid": "note-text" }
        }) }}
        {{ govukButton({
          text: "Add note",
          attributes: { "data-testid": "add-note-submit" }
        }) }}
      </form>

      {% if workItem.notes and workItem.notes.length > 0 %}
        <ol class="govuk-list" data-testid="work-item-notes">
          {% for note in workItem.notes %}
            <li class="govuk-!-margin-bottom-4" data-testid="work-item-note-{{ note.id }}">
              <p class="govuk-body govuk-!-margin-bottom-1" style="white-space: pre-wrap">{{ note.text }}</p>
              <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-0">
                {{ note.createdByName or note.createdBy or "Unknown" }} — {{ note.createdAt }}
              </p>
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-notes">
          No notes have been added to this work item.
        </p>
      {% endif %}

      {# --------------------------- Audit log ---------------------------- #}
      {# RA-97. Framework-provided audit timeline: every state-changing    #}
      {# engine call (task complete, action applied, assignment change,   #}
      {# note added) appends one entry on the backend. Projected          #}
      {# chronologically (oldest-first) so we render top-to-bottom         #}
      {# without re-sorting.                                              #}
      <h2 class="govuk-heading-m" id="audit-log">Audit log</h2>

      {% if workItem.auditLog and workItem.auditLog.length > 0 %}
        <ol class="govuk-list" data-testid="work-item-audit-log">
          {% for entry in workItem.auditLog %}
            <li class="govuk-!-margin-bottom-3" data-testid="work-item-audit-entry-{{ entry.id }}">
              <p class="govuk-body govuk-!-margin-bottom-1">
                <strong>{{ entry.actionDisplayName }}</strong>
                {% if entry.summary %}
                  — {{ entry.summary }}
                {% endif %}
              </p>
              <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-0">
                {{ entry.createdByName or entry.createdBy or "System" }} — {{ entry.createdAt }}
              </p>
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <p class="govuk-body" data-testid="work-item-no-audit-log">
          No actions have been recorded against this work item yet.
        </p>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-third">
      <h2 class="govuk-heading-s">Payload</h2>
      <pre class="govuk-!-font-size-14"
           data-testid="work-item-payload"><code>{{ workItem.payloadJson }}</code></pre>
    </div>
  </div>
{% endblock %}
