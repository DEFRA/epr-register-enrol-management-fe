{% extends 'layouts/page.njk' %}
{# containerClasses = "app-width-container--wide" is injected by the        #}
{# controller so govuk/template.njk widens the container to 1200 px.        #}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block content %}
  {# ── Row 1: heading + optional "Create work item" button ─────────────── #}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {{ appHeading({
        text: heading,
        caption: "All work items currently in the case management system"
      }) }}
      {% if showCreateWorkItem %}
        {{ govukButton({
          text: "Create work item",
          href: "/work-items/re-accreditation/new",
          classes: "govuk-button--start govuk-!-font-size-19",
          attributes: { "data-testid": "work-items-create-link" }
        }) }}
      {% endif %}
    </div>
  </div>

  {# ── Row 2: filter sidebar (1/4) + results area (3/4) side-by-side ───── #}
  {# The 1200 px container gives the table ~900 px of width, comfortably    #}
  {# preventing column wrapping at typical viewport sizes.                  #}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-quarter app-work-items__filter">
      <form method="get" action="/work-items" novalidate data-testid="work-items-filter-form">
        {# Hidden marker so the controller can tell a real form submission #}
        {# (possibly with everything unchecked) apart from a fresh GET of the #}
        {# page, and decide whether to apply role-based filter defaults (RA-125). #}
        <input type="hidden" name="filtersApplied" value="1">
        <h2 class="govuk-heading-m">Filter</h2>

        {{ govukInput({
          id: "orgId",
          name: "orgId",
          label: { text: "Org ID", classes: "govuk-label--s" },
          value: filters.orgId,
          spellcheck: false,
          autocomplete: "off",
          attributes: { "data-testid": "work-items-filter-org-id" }
        }) }}

        {{ govukInput({
          id: "registrationId",
          name: "registrationId",
          label: { text: "Registration ID", classes: "govuk-label--s" },
          value: filters.registrationId,
          spellcheck: false,
          autocomplete: "off",
          attributes: { "data-testid": "work-items-filter-registration-id" }
        }) }}

        {{ govukInput({
          id: "orgName",
          name: "orgName",
          label: { text: "Org name", classes: "govuk-label--s" },
          value: filters.orgName,
          spellcheck: false,
          autocomplete: "off",
          attributes: { "data-testid": "work-items-filter-org-name" }
        }) }}

        {% if typeOptions.length > 0 %}
          {{ govukCheckboxes({
            idPrefix: "filter-type",
            name: "typeId",
            classes: "govuk-checkboxes--small",
            fieldset: { legend: { text: "Type", classes: "govuk-fieldset__legend--s" } },
            items: typeOptions
          }) }}
        {% endif %}

        {% if stateOptions.length > 0 %}
          {{ govukCheckboxes({
            idPrefix: "filter-state",
            name: "stateId",
            classes: "govuk-checkboxes--small",
            fieldset: { legend: { text: "State", classes: "govuk-fieldset__legend--s" } },
            items: stateOptions
          }) }}
        {% endif %}

        {% if nationOptions.length > 0 %}
          {{ govukCheckboxes({
            idPrefix: "filter-nation",
            name: "nation",
            classes: "govuk-checkboxes--small",
            fieldset: { legend: { text: "Regulator", classes: "govuk-fieldset__legend--s" } },
            items: nationOptions
          }) }}
        {% endif %}

        {{ govukCheckboxes({
          idPrefix: "filter-applicant-type",
          name: "applicantType",
          classes: "govuk-checkboxes--small",
          fieldset: { legend: { text: "Applicant type", classes: "govuk-fieldset__legend--s" } },
          hint: { text: "Filtering not yet available" },
          items: [
            { value: "reprocessor", text: "Reprocessor", disabled: true },
            { value: "exporter", text: "Exporter", disabled: true }
          ]
        }) }}

        {# Assignee filter (RA-95). The "Specific user…" radio reveals a #}
        {# select listing the assignable-users directory. Same options are #}
        {# offered to every user; only the assign *write* is role-gated. #}
        {% set assigneeUserSelectHtml %}
          {{ govukSelect({
            id: "filter-assignee-user",
            name: "assigneeUserId",
            label: { text: "Assigned to", classes: "govuk-label--s" },
            items: assigneeUserOptions,
            attributes: { "data-testid": "work-items-filter-assignee-user" }
          }) }}
        {% endset %}

        {% set assigneeRadioItems = [] %}
        {% for option in assigneeFilterOptions %}
          {% if option.conditional %}
            {% set _ = assigneeRadioItems.push({
              value: option.value,
              text: option.text,
              checked: option.checked,
              conditional: { html: assigneeUserSelectHtml }
            }) %}
          {% else %}
            {% set _ = assigneeRadioItems.push({
              value: option.value,
              text: option.text,
              checked: option.checked
            }) %}
          {% endif %}
        {% endfor %}

        {{ govukRadios({
          idPrefix: "filter-assignee",
          name: "assigneeMode",
          classes: "govuk-radios--small",
          fieldset: { legend: { text: "Assignment", classes: "govuk-fieldset__legend--s" } },
          items: assigneeRadioItems
        }) }}

        {{ govukCheckboxes({
          idPrefix: "filter-include-archived",
          name: "includeArchived",
          classes: "govuk-checkboxes--small",
          fieldset: { legend: { text: "Archived", classes: "govuk-fieldset__legend--s" } },
          items: [
            {
              value: "true",
              text: "Show archived",
              checked: filters.includeArchived,
              attributes: { "data-testid": "work-items-filter-include-archived" }
            }
          ]
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({ text: "Apply filters", attributes: { "data-testid": "work-items-filter-apply" } }) }}
          {% if hasFilters %}
            <a class="govuk-link" href="/work-items" data-testid="work-items-filter-clear">Clear filters</a>
          {% endif %}
        </div>
      </form>
    </div>

    <div class="govuk-grid-column-three-quarters app-work-items__results">
      {% if not ok %}
        {# `text:` is auto-escaped by the govuk macro and wrapped in the   #}
        {# notification-banner heading paragraph; never concatenate raw    #}
        {# backend strings into `html:` (epr-6fi).                         #}
        {{ govukNotificationBanner({
          titleText: "Could not reach the backend",
          text: error or "Unknown error"
        }) }}
      {% else %}
        <p class="govuk-body" data-testid="work-items-summary">
          {% if totalCount === 0 %}
            {% if hasFilters %}
              No work items match your filters.
            {% else %}
              No work items have been submitted yet.
            {% endif %}
          {% else %}
            Showing page <strong>{{ page }}</strong> of <strong>{{ totalPages }}</strong>
            ({{ totalCount }} work item{% if totalCount != 1 %}s{% endif %}{% if filterSummary.description %} — {{ filterSummary.description }}{% endif %})
          {% endif %}
        </p>

        {% if items.length > 0 %}
          {% set rows = [] %}
          {% for item in items %}
            {% set stateTagHtml %}{{ govukTag({ text: item.stateDisplayName, classes: item.stateTagClass, attributes: { "data-testid": "work-item-state-tag-" + item.id } }) }}{% endset %}
            {# Render the link via a Nunjucks capture so each interpolation #}
            {# is auto-escaped — never concatenate `item.id` raw into       #}
            {# `html:` (epr-6fi). `urlencode` for the href, `escape` for    #}
            {# the attribute and link text.                                  #}
            {% set itemLinkHtml %}<a class="govuk-link" href="/work-items/{{ item.id | urlencode }}" data-testid="work-item-link-{{ item.id }}">{{ item.id }}</a>{% endset %}
            {% set slaTagHtml %}
              {%- if item.slaTagText %}
                {{- govukTag({ text: item.slaTagText, classes: item.slaTagClass, attributes: { "data-testid": "work-item-sla-tag-" + item.id } }) }}
                {%- if item.slaRemainingText %}
                  <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0">{{ item.slaRemainingText }}</p>
                {%- endif %}
              {%- else %}—{% endif %}
            {% endset %}
            {% set _ = rows.push([
              { html: itemLinkHtml },
              { text: item.typeDisplayName, classes: "app-!-white-space-nowrap" },
              { html: stateTagHtml },
              { text: item.orgName or "—" },
              { text: item.material or "—" },
              { text: item.submittedAt | formatDateTimeGds, classes: "app-!-white-space-nowrap" },
              { text: item.submittedBy or "—" },
              { text: item.assigneeDisplayName or "Unassigned" },
              { html: slaTagHtml },
              { text: item.archivedAt or "—", classes: "app-!-white-space-nowrap", attributes: { "data-testid": "work-item-archived-at-" + item.id } }
            ]) %}
          {% endfor %}

          <div class="app-work-items__table-wrapper">
            {{ govukTable({
              head: [
                { text: "Application ref" },
                { text: "Type", classes: "app-!-white-space-nowrap" },
                { text: "State" },
                { text: "Org name" },
                { text: "Material" },
                { text: "Submitted", classes: "app-!-white-space-nowrap" },
                { text: "Submitted by", classes: "app-!-white-space-nowrap" },
                { text: "Assigned to", classes: "app-!-white-space-nowrap" },
                { text: "Due date (SLA)" },
                { text: "Archived", classes: "app-!-white-space-nowrap" }
              ],
              rows: rows,
              attributes: { "data-testid": "work-items-table" }
            }) }}
          </div>

          {% if pagination %}
            {{ govukPagination(pagination) }}
          {% endif %}
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endblock %}
