{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{# RA-131: confirm step for the Extend SLA flow. The team leader has    #}
{# already entered the number of days and a reason on the input page;   #}
{# this page summarises what is about to happen and asks them to        #}
{# confirm before we hit the backend. No browser JS — pure server-side  #}
{# wizard with hidden inputs carried through to the confirm POST.       #}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Work item " + workItem.id
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <p class="govuk-body" data-testid="sla-extend-confirm-intro">
        Check the details below. Confirming will extend the SLA clock for
        this work item.
      </p>

      {% set rows = [
        {
          key: { text: "Extension" },
          value: { text: additionalDays + (" day" if additionalDays == 1 else " days") }
        }
      ] %}

      {% if newDueAt %}
        {% set rows = (rows.push({
          key: { text: "New due date" },
          value: { text: newDueAt | formatDate }
        }), rows) %}
      {% endif %}

      {% set rows = (rows.push({
        key: { text: "Reason" },
        value: { text: values.reason }
      }), rows) %}

      {{ govukSummaryList({
        rows: rows,
        attributes: { "data-testid": "sla-extend-confirm-summary" }
      }) }}

      <form method="post"
            action="{{ formAction }}"
            novalidate
            data-testid="sla-extend-confirm-form">
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" name="reason" value="{{ values.reason }}" />
        <input type="hidden" name="additionalDays" value="{{ values.additionalDays }}" />

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Confirm",
            attributes: { "data-testid": "sla-extend-confirm-submit" }
          }) }}
          <a class="govuk-link"
             data-testid="sla-extend-confirm-cancel"
             href="{{ cancelHref }}">Cancel</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
