{% extends 'layouts/page.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Work item " + workItemId
  }) }}

  {# Render the heading via a Nunjucks capture so the backend error string #}
  {# is auto-escaped — never concatenate raw backend output into `html:`    #}
  {# (epr-6fi). The capture preserves the test-id hook the controller       #}
  {# tests rely on.                                                         #}
  {% set detailErrorHtml %}<p class="govuk-notification-banner__heading" data-testid="work-item-detail-error">{{ error or "Unknown error" }}</p>{% endset %}
  {{ govukNotificationBanner({
    titleText: "Could not reach the backend",
    html: detailErrorHtml
  }) }}

  <p class="govuk-body">
    <a class="govuk-link" href="/work-items">Back to all work items</a>
  </p>
{% endblock %}
