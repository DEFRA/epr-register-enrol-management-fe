{# ------------------------------------------------------------------- #}
{# Re-accreditation detail template (v1) — RA-98 + RA-132.              #}
{#                                                                      #}
{# Type-specific view selected by the framework's detail controller     #}
{# whenever a work item's `(typeId, templateVersion)` is                 #}
{# `(re-accreditation, v1)`. Extends the generic detail template to     #}
{# inherit envelope summary, assignment, tasks and audit log rendering, #}
{# and overrides the narrow blocks the generic template exposes to add  #}
{# re-accreditation-specific behaviour:                                  #}
{#                                                                      #}
{#  - RA-132 "Approve" CTA in `primaryActions`, gated by the controller #}
{#    via `workItem.canApproveDirectly`.                                #}
{#  - Terminal-state read-only mode: when the work item is approved,    #}
{#    rejected or withdrawn, suppress the decision action panel and     #}
{#    render a status tag + (for approvals) the issued accreditation    #}
{#    metadata in `summaryListExtra`.                                   #}
{# ------------------------------------------------------------------- #}

{% extends 'work-items/detail.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}

{% block content %}
  <div data-testid="re-accreditation-detail">
    {{ govukNotificationBanner({
      titleText: "Re-accreditation work item",
      text: "Reference implementation showing how a module supplies its own detail template (RA-98)."
    }) }}
    {{ super() }}
  </div>
{% endblock %}

{# RA-156. Approve CTA moved into the actionsPanel button group so it    #}
{# renders alongside Reject and Withdraw.                                #}
{% block primaryActions %}{% endblock %}

{% block approveAction %}
  {% if workItem.canApproveDirectly %}
    <div data-testid="re-accreditation-approve-cta">
      {{ govukButton({
        text: "Approve",
        href: workItem.approveHref,
        attributes: { "data-testid": "action-approve" }
      }) }}
    </div>
  {% endif %}
{% endblock %}

{# RA-132. Once the work item reaches a terminal state, suppress the     #}
{# generic action panel — those would be either no-op or rejected by     #}
{# the backend, which is confusing. Show the status as a govuk tag so    #}
{# the read-only nature is obvious.                                      #}
{% block actionsPanel %}
  {% if workItem.isReadOnlyState %}
    <h2 class="govuk-heading-m">Outcome</h2>
    <p class="govuk-body" data-testid="re-accreditation-readonly-actions">
      This work item is in a final state. No further decision actions are available.
    </p>
    <p class="govuk-body">
      {{ govukTag({
        text: workItem.stateDisplayName,
        classes: workItem.stateTagClasses,
        attributes: { "data-testid": "re-accreditation-state-tag" }
      }) }}
    </p>
  {% else %}
    {{ super() }}
  {% endif %}
{% endblock %}

{# RA-132 / RA-133 / RA-177. When the work item has been approved,      #}
{# surface the issued accreditation metadata from the backend           #}
{# (`payload.accreditationId`, `payload.accreditationStartDate`,        #}
{# `payload.accreditationYear`) ABOVE the envelope summary as a         #}
{# confirmation panel + a summary list so it is the first thing the     #}
{# user sees after approving. RA-177 moved this from `summaryListExtra` #}
{# (which renders below the envelope attributes) to `summaryListBefore` #}
{# so the success message sits above the attributes.                    #}
{% block summaryListExtra %}
  <p class="govuk-body">
    <a class="govuk-link" href="/work-items/{{ workItem.id }}/application-details" data-testid="view-application-details-link">
      View full application details
    </a>
  </p>

  {% set p = workItem.payload %}
  {% if p %}
    <h2 class="govuk-heading-m">Application details</h2>
    {% set payloadRows = [] %}
    {% if p.organisationName %}
      {% set payloadRows = (payloadRows.push({ key: { text: "Organisation name" }, value: { html: '<span data-testid="payload-organisation-name">' + (p.organisationName | escape) + '</span>' } }), payloadRows) %}
    {% endif %}
    {% if p.materialsHandled and p.materialsHandled.length %}
      {% set payloadRows = (payloadRows.push({ key: { text: "Materials handled" }, value: { html: '<span data-testid="payload-materials-handled">' + (p.materialsHandled | join(", ") | escape) + '</span>' } }), payloadRows) %}
    {% endif %}
    {% if p.accreditationYear %}
      {% set payloadRows = (payloadRows.push({ key: { text: "Accreditation year" }, value: { html: '<span data-testid="payload-accreditation-year">' + (p.accreditationYear | string | escape) + '</span>' } }), payloadRows) %}
    {% endif %}
    {% if p.siteAddress %}
      {% set payloadRows = (payloadRows.push({ key: { text: "Site address" }, value: { html: '<span data-testid="payload-site-address">' + (p.siteAddress | escape) + '</span>' } }), payloadRows) %}
    {% endif %}
    {% if p.siteAddressPostcode %}
      {% set payloadRows = (payloadRows.push({ key: { text: "Site postcode" }, value: { html: '<span data-testid="payload-site-postcode">' + (p.siteAddressPostcode | escape) + '</span>' } }), payloadRows) %}
    {% endif %}
    {% if p.operatorEmail %}
      {% set payloadRows = (payloadRows.push({ key: { text: "Operator email" }, value: { html: '<span data-testid="payload-operator-email">' + (p.operatorEmail | escape) + '</span>' } }), payloadRows) %}
    {% endif %}
    {% if payloadRows.length %}
      {{ govukSummaryList({ attributes: { "data-testid": "re-accreditation-payload" }, rows: payloadRows }) }}
    {% endif %}
  {% endif %}
{% endblock %}

{% block summaryListBefore %}
  {% if workItem.decisionMetadata %}
    {{ govukPanel({
      titleText: "Accreditation issued",
      html: 'Accreditation ID<br><strong data-testid="re-accreditation-approval-panel-id">'
            + (workItem.decisionMetadata.accreditationId | escape) + '</strong>',
      attributes: { "data-testid": "re-accreditation-approval-panel" }
    }) }}
    {{ govukSummaryList({
      attributes: { "data-testid": "re-accreditation-decision-metadata" },
      rows: [
        {
          key: { text: "Accreditation ID" },
          value: {
            html: '<span data-testid="re-accreditation-accreditation-id">'
                  + (workItem.decisionMetadata.accreditationId | escape) + '</span>'
          }
        },
        {
          key: { text: "Accreditation start date" },
          value: {
            html: '<span data-testid="re-accreditation-accreditation-start-date">'
                  + (workItem.decisionMetadata.accreditationStartDateFormatted | escape)
                  + '</span>'
          }
        },
        {
          key: { text: "Accreditation year" },
          value: {
            html: '<span data-testid="re-accreditation-accreditation-year">'
                  + ((workItem.decisionMetadata.accreditationYear or '—') | escape)
                  + '</span>'
          }
        }
      ]
    }) }}
  {% endif %}
{% endblock %}
