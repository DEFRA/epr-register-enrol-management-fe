{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">Stub Login</h1>
      <p class="govuk-body">
        This is a development stub. Choose a role and optionally a nation to log in as.
      </p>

      {% if error %}
        <div class="govuk-error-summary">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li>{{ error }}</li>
            </ul>
          </div>
        </div>
      {% endif %}

      <form method="POST" action="/auth/stub/login">
        <input type="hidden" name="crumb" value="{{ crumb }}" />

        <div class="govuk-form-group">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
              <h2 class="govuk-fieldset__heading">Role</h2>
            </legend>
            <div class="govuk-radios">
              {% for option in roleOptions %}
                <div class="govuk-radios__item">
                  <input
                    class="govuk-radios__input"
                    id="role-{{ loop.index }}"
                    name="role"
                    type="radio"
                    value="{{ option.value }}"
                    {% if loop.index === 2 %}checked{% endif %}
                  >
                  <label class="govuk-label govuk-radios__label" for="role-{{ loop.index }}">
                    {{ option.label }}
                  </label>
                </div>
              {% endfor %}
            </div>
          </fieldset>
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="nation">
            Nation
          </label>
          <div id="nation-hint" class="govuk-hint">
            Select a nation to restrict your worklist view. Leave as "None" to see all nations.
          </div>
          <select class="govuk-select" id="nation" name="nation" aria-describedby="nation-hint">
            {% for option in nationOptions %}
              <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>

        <button class="govuk-button" type="submit">Log in</button>
      </form>
    </div>
  </div>
{% endblock %}
