{% extends 'layouts/page.njk' %}

{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Frontend ↔ backend integration check"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body" data-testid="app-page-body">
        This page calls the case management backend's <code>/health</code>
        endpoint and reports the result.
      </p>

      {% if result.ok %}
        {{ govukTag({ text: "Reachable", classes: "govuk-tag--green" }) }}
      {% else %}
        {{ govukTag({ text: "Unreachable", classes: "govuk-tag--red" }) }}
      {% endif %}

      {{ govukSummaryList({
        rows: [
          { key: { text: "Backend URL" }, value: { text: backendUrl } },
          { key: { text: "HTTP status" }, value: { text: result.status or "n/a" } },
          { key: { text: "Response body" }, value: { text: result.body or "n/a" } },
          { key: { text: "Error" }, value: { text: result.error or "none" } }
        ]
      }) }}
    </div>
  </div>
{% endblock %}
